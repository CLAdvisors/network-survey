DB_USER=postgres
DB_PASSWORD=replace-me
DB_HOST=127.0.0.1
DB_PORT=5432
FRONTEND_URL=http://localhost:3001
SURVEY_URL=http://localhost:3002
NODE_ENV=development
SESSION_SECRET=replace-me
# Public dashboard signup defaults to enabled only for local/dev/test.
# Set false for production/staging unless invite/admin-created accounts are explicitly supported.
ALLOW_PUBLIC_SIGNUP=true
# Optional throttling overrides (15-minute windows).
AUTH_RATE_LIMIT_MAX=20
RESPONDENT_RATE_LIMIT_MAX=120
# Optional for email sending features.
RESEND_API_KEY=replace-me
# Optional for local DB bootstrap admin created by `npm run db:setup`.
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=admin123
# Safety valve. Keep false for normal local workflows.
ALLOW_NON_LOCAL_DB_SETUP=false